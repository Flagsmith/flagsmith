    "react-async-script": "1.2.0",
    "react-datepicker": "^8.1.0",
    "react-device-detect": "1.9.9",
    "react-diff-viewer-continued": "^3.3.1",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.2.3",
    "react-markdown": "^8.0.5",
    "react-maskedinput": "4.0.1",
