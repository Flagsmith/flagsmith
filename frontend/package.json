    "yaml": "^2.8.3",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@dword-design/eslint-plugin-import-alias": "^2.0.7",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/addon-docs": "^10.3.3",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.2",
    "@storybook/react-webpack5": "^10.3.3",
    "@types/archiver": "^6.0.2",
    "@types/classnames": "^2.3.1",
    "@types/color": "^3.0.3",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/rc-switch": "^1.9.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-virtualized": "^9.22.0",
    "@typescript-eslint/eslint-plugin": "5.4.0",
    "@typescript-eslint/parser": "5.4.0",
    "archiver": "^7.0.1",
    "chromatic": "^15.2.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-import": "2.27.5",
    "eslint-plugin-import-alias": "^1.2.0",
    "eslint-plugin-prettier": "^3.4.0",
    "eslint-plugin-react": "7.28.0",
    "eslint-plugin-react-hooks": "4.3.0",
    "eslint-plugin-sort-destructure-keys": "^1.4.0",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-storybook": "^10.3.3",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^8.0.2",
    "jest": "^30.2.0",
    "lint-staged": "^12.3.4",
    "minimist": "^1.2.8",
    "nodemon": "^3.0.1",
    "playwright": "^1.58.2",
    "prettier": "^2.5.1",
    "raw-loader": "^4.0.2",
    "react-refresh": "^0.14.2",
    "ssgrtk": "^0.3.5",
    "storybook": "^10.3.3",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": "eslint --fix",
    "common/theme/tokens.json": "npm run generate:tokens && git add common/theme/tokens.ts web/styles/_tokens.scss web/styles/_token-utilities.scss documentation/TokenReference.generated.stories.tsx"
  },
  "optionalDependencies": {
    "webpack": "^5.105.4"
  }
